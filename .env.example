# Copy this file to .env and fill in real values before running the app.
# NEVER commit .env to version control.

# Required — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-secret-key-here
JWT_SECRET_KEY=your-random-jwt-secret-key-here

# Optional: override default SQLite path
# DATABASE_URL=sqlite:///database/refundiq.db

# Optional: email notifications (SMTP)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your@email.com
# MAIL_PASSWORD=your-app-password
# MAIL_DEFAULT_SENDER=noreply@refundiq.com

# Optional: Gemini AI chat assistant
# GEMINI_API_KEY=your-gemini-api-key

# Optional: CORS allowed origins (default: *)
# ALLOWED_ORIGINS=https://yourdomain.com
